DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=slbus
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_MIGRATIONS_RUN=false

# Frontend origins allowed by CORS — comma-separated, no trailing slash.
# Required for the refresh-token cookie to flow cross-origin.
CORS_ORIGINS=http://localhost:5173

# Swagger server dropdown — shown at the top of /api/v1/swagger-ui
SWAGGER_LOCAL_URL=http://localhost:4000
SWAGGER_PROD_URL=https://api.codescapelabs.com

# Admin seed (used to bootstrap the first Admin user on app startup)
ADMIN_EMAIL=admin@example.com
ADMIN_PHONE=+94770000000
ADMIN_PASSWORD=changeme

# Redis cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_USERNAME=
REDIS_DB=0
REDIS_TLS=false
CACHE_TTL_MS=60000

# File uploads (Cloudinary)
